
import cv2
import mediapipe as mp
import pyautogui
import time
import os

# PyAutoGUI Safety & Delay
pyautogui.PAUSE = 0.1
pyautogui.FAILSAFE = True

# MediaPipe setup
GestureRecognizer = mp.tasks.vision.GestureRecognizer
GestureRecognizerOptions = mp.tasks.vision.GestureRecognizerOptions
VisionRunningMode = mp.tasks.vision.RunningMode

latest_gesture = "None"
last_triggered_gesture = "None"
current_status_text = "Waiting for Gesture..."

# --- Landmark-based Index Finger Up detection ---
mp_hands = mp.solutions.hands
hands = mp_hands.Hands(max_num_hands=1, min_detection_confidence=0.7)

def detect_index_finger_up(frame):
    rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    results = hands.process(rgb)
    if results.multi_hand_landmarks:
        hand = results.multi_hand_landmarks[0]
        lm = hand.landmark
        # Index finger tip vs PIP joint
        index_tip = lm[mp_hands.HandLandmark.INDEX_FINGER_TIP]
        index_pip = lm[mp_hands.HandLandmark.INDEX_FINGER_PIP]
        middle_tip = lm[mp_hands.HandLandmark.MIDDLE_FINGER_TIP]
        middle_pip = lm[mp_hands.HandLandmark.MIDDLE_FINGER_PIP]

        # Condition: index up, middle down
        if index_tip.y < index_pip.y and middle_tip.y > middle_pip.y:
            return "Index_Finger_Up"
    return None

# Gesture callback
def render_callback(result: mp.tasks.vision.GestureRecognizerResult, output_image: mp.Image, timestamp_ms: int):
    global latest_gesture
    if result.gestures and len(result.gestures) > 0:
        latest_gesture = result.gestures[0][0].category_name
    else:
        latest_gesture = "None"

# Model path
model_path = r"C:\Users\Trishita Sarkar\opencv\finger gesture\gesture_recognizer.task"
options = GestureRecognizerOptions(
    base_options=mp.tasks.BaseOptions(model_asset_path=model_path),
    running_mode=VisionRunningMode.LIVE_STREAM,
    result_callback=render_callback
)

# Cooldown
cooldown_duration = 2.0
last_action_time = 0

# Gesture actions
gesture_actions = {
    "Victory": ("Opening New Tab", lambda: pyautogui.hotkey('ctrl', 't')),
    "Thumb_Up": ("Closing Current Tab", lambda: pyautogui.hotkey('ctrl', 'w')),
    "Open_Palm": ("Switching Tab", lambda: pyautogui.hotkey('ctrl', 'tab')),
    "Thumb_Down": ("Minimizing Window", lambda: pyautogui.hotkey('win', 'down')),
    "Closed_Fist": ("Reopen Last Tab", lambda: pyautogui.hotkey('ctrl', 'shift', 't')),
    "Pointing_Up": ("Refreshing Tab", lambda: pyautogui.hotkey('ctrl', 'r')),
    "Index_Finger_Up": ("Open Google Chrome", lambda: os.system("start chrome"))
}

# Camera loop
cap = cv2.VideoCapture(0)
frame_timestamp_ms = 0

with GestureRecognizer.create_from_options(options) as recognizer:
    print("Gesture Recognizer started safely!")
    while cap.isOpened():
        success, frame = cap.read()
        if not success:
            break

        frame = cv2.flip(frame, 1)
        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_frame)

        frame_timestamp_ms += 33
        recognizer.recognize_async(mp_image, frame_timestamp_ms)

        # Landmark-based check for Index Finger Up
        custom_gesture = detect_index_finger_up(frame)
        if custom_gesture:
            latest_gesture = custom_gesture

        current_time = time.time()

        if latest_gesture == "None":
            last_triggered_gesture = "None"
        elif latest_gesture in gesture_actions and latest_gesture != last_triggered_gesture:
            if current_time - last_action_time > cooldown_duration:
                action_text, action_func = gesture_actions[latest_gesture]
                current_status_text = f"Action: {action_text}"
                print(f"Triggered: {latest_gesture} -> {action_text}")
                action_func()
                last_action_time = current_time
                last_triggered_gesture = latest_gesture

        # UI Feedback
        cv2.rectangle(frame, (15, 15), (550, 85), (0, 0, 0), -1)
        cv2.putText(frame, f"Detected: {latest_gesture}", (20, 45),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 255), 2)
        cv2.putText(frame, current_status_text, (20, 75),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 0), 2)

        cv2.imshow('Google Chrome Gesture Controller', frame)
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

cap.release()
cv2.destroyAllWindows()
